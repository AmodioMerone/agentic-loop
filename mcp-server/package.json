{
  "name": "agent-comms-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server backing the multi-agent comms with SQLite (node:sqlite, no native deps).",
  "type": "module",
  "main": "server.js",
  "bin": {
    "agent-comms-mcp": "server.js"
  },
  "scripts": {

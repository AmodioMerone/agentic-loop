    "retention": "node retention.js",
    "retention:dry": "node retention.js --dry-run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  }
}
